{
  "name": "tsdiff",
  "version": "0.1.0",
  "description": "Detect breaking changes in a TypeScript package's public API surface",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tsdiff": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "api",
    "diff",
    "breaking-changes",
    "semver",
    "oasdiff"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "vitest": "^2.1.0"
  }
}
